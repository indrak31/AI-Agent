# Monad testnet values verified from the official Monad docs on June 25, 2026.
# Re-check before live testing:
# - Network info: https://docs.monad.xyz/developer-essentials/testnets
# - Wallet setup: https://docs.monad.xyz/guides/add-monad-to-wallet/testnet
# - Faucet: https://faucet.monad.xyz
MONAD_TESTNET_RPC_URL=https://testnet-rpc.monad.xyz
MONAD_TESTNET_CHAIN_ID=10143
MONAD_EXPLORER_BASE_URL=https://testnet.monadvision.com
MONADSCAN_BASE_URL=https://testnet.monadscan.com
DEPLOYER_PRIVATE_KEY=0xYOUR_TESTNET_PRIVATE_KEY
OWNER_ADDRESS=0xYOUR_OWNER_WALLET
ETHERSCAN_API_KEY=your_etherscan_v2_api_key

# Contract deployment defaults. KillSwitch uses 18-decimal fixed-point trade units.
HELLO_WORLD_GREETING=Hello Monad
KILLSWITCH_DAILY_CAP=500
KILLSWITCH_PER_TRADE_LIMIT=100
KILLSWITCH_COOLDOWN_SECONDS=300
KILLSWITCH_ADDRESS=0xYOUR_DEPLOYED_KILLSWITCH

# Pyth contracts verified from Monad's Oracles page on June 25, 2026.
# Stable price feeds contract:
PYTH_CONTRACT_ADDRESS=0x2880aB155794e7179c9eE2e38200202908C17B43
# Beta contract includes additional feeds such as MON/USDC; use only if you need those.
PYTH_BETA_CONTRACT_ADDRESS=0xad2B52D2af1a9bD5c561894Cdd84f7505e1CD0B5
# Verify these feed IDs against Pyth's official price feed ID page before running.
PYTH_ETH_USD_FEED_ID=0xff61491a931112ddf1bd8147cd1b641375f79f5825126d665480874634fd0ace
PYTH_USDC_USD_FEED_ID=0xeaa020c61cc479712813461ce153894a96a6c00b21ed0cfc2798d1f9a9e9c94a
PYTH_MAX_STALENESS_SECONDS=90

# LLM reasoning layer
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_MODEL=minimax-m2.7

# DEX assumptions. This scaffold assumes a PancakeSwap V2-compatible router interface.
# Confirm the live router address from the DEX's official Monad docs before enabling swaps.
DEX_NAME=PancakeSwap
DEX_ROUTER_ADDRESS=0xD99D1c33F9fC3444f8101754aBC46c52416550D1
DEX_BASE_TOKEN_ADDRESS=0xFb8bf4c1CC7a94c73D209a149eA2AbEa852BC541
DEX_QUOTE_TOKEN_ADDRESS=0x754704Bc059F8C67012fEd69BC8A327a5aafb603
DEX_BASE_TOKEN_SYMBOL=WMON
DEX_QUOTE_TOKEN_SYMBOL=USDC
DEX_BASE_TOKEN_DECIMALS=18
DEX_QUOTE_TOKEN_DECIMALS=6
TRADE_RECIPIENT=0xYOUR_OWNER_WALLET
SLIPPAGE_BPS=100
SWAP_DEADLINE_SECONDS=120
ENABLE_LIVE_SWAPS=false

# Agent and dashboard runtime
AGENT_POLL_SECONDS=30
EVENT_HISTORY_LIMIT=25
EVENT_LOOKBACK_BLOCKS=500
BASE_ORDER_SIZE=25
EMA_SHORT_PERIOD=5
EMA_LONG_PERIOD=20
EMA_MIN_SEPARATION_BPS=10
SIMULATED_STARTING_BASE_BALANCE=0
SIMULATED_STARTING_QUOTE_BALANCE=1000
SHARED_STATE_PATH=.runtime/shared_state.json
REASONING_MAX_CHARS=4000

